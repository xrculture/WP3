<?xml version="1.0" encoding="UTF-8"?>
<Protocol version="1.0">
	<RegistrationRequest>
		<ProviderID>RDF LTD</ProviderID>
		<ServiceName>RDF LTD Gaussian Splatting Viewer</ServiceName>
		<ServiceType>Viewer</ServiceType>
		<EndPoint>http://xrcultureviewer.rdf.bg:30026/GaussianSplattingViewer</EndPoint>
		<SessionToken>%SESSION_TOKEN%</SessionToken>		
		<ContactEmail>admin@example.com</ContactEmail>
		<BackEnd>
			<Access-Control-Allow-Origin>https://developer.mozilla.org</Access-Control-Allow-Origin>
			<!-- for CORS. The wildcard * can be used -->
			<SupportedOptions>
				<Architecture value="REST">
					<Access-Control-Allow-Method>*</Access-Control-Allow-Method>
				</Architecture>
				<Analytics>
					<UsageTracking enabled="False" />
				</Analytics>
				<ProgressiveLoading value="False" />
				<TimeMachine value="False" />
				<FileFormats>
					<Format extension=".splat" mimetype="application/octet-stream" native="False" />
					<Format extension=".ply" mimetype="application/octet-stream" native="False" />
				</FileFormats>
				<DataProviders></DataProviders>
				<FullText></FullText>
				<Protocols>
					<Protocol>oEmbed</Protocol>
				</Protocols>
				<Authentication></Authentication>
			</SupportedOptions>
		</BackEnd>
		<FrontEnd>
			<GUI>
				<ViewType value="False" />
				<Languages>
					<Language default="True">en-US</Language>
				</Languages>
				<MobileOptimization value="False" />
				<MaxPolygonCount>1000000</MaxPolygonCount>
				<MaxTextureSize>4096</MaxTextureSize>
			</GUI>
			<SupportedOptions>
				<Scene>
					<!-- Scene Setup and Update -->
					<Autoload value="False" />
					<Zoom value="False" />
					<Pan value="False" />
					<BackgroundColor value="000,FFF,DD2500,ALL" default="000" />
					<!-- RGB -->
					<View value="Top,Bottom,Front,Back,Left,Right" default="Front" />
					<Lights value="False" />
					<VR value="False" />
				</Scene>
				<MultipleModels></MultipleModels>
				<ElementSelection value="none>"></ElementSelection>
				<Elements></Elements>
				<Measuring></Measuring>
				<Attachments></Attachments>
				<CustomBBox value="False" />
			</SupportedOptions>
		</FrontEnd>
		<Timestamp>2025-05-20T14:00:00Z</Timestamp>
	</RegistrationRequest>
</Protocol>
