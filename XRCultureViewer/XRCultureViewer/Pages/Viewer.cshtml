@page
@model XRCultureViewer.Pages.ViewerModel
@{
    ViewData["Title"] = "Viewer";
    Layout = "_ViewerLayout";

    var baseUrl = $"{Request.Scheme}://{Request.Host}{Request.PathBase}";
    var viewerUrl = Uri.EscapeDataString($"{baseUrl}/Viewer?model={Model.Model}");
    var oembedJson = $"{baseUrl}/oembed?url={viewerUrl}&format=json";
    var oembedXml = $"{baseUrl}/oembed?url={viewerUrl}&format=xml";
}

@section HeadContent {
    <link rel="alternate" type="application/json+oembed" href="@oembedJson" title="3D Model Viewer" />
    <link rel="alternate" type="text/xml+oembed" href="@oembedXml" title="3D Model Viewer" />
}

<iframe src="~/viewer/viewer.html?model=@Model.Model" style="width: 100%; height: 100vh; border: none;"></iframe>